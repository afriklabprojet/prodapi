# Configuration de l'application Courier Flutter
# Copier ce fichier en .env et remplir les valeurs

# API Backend
# Développement: http://localhost:8000/api ou http://127.0.0.1:8000/api
# Production: https://drlpharma.com/api
API_BASE_URL=http://127.0.0.1:8000/api

# Google Maps API Key (restreindre dans Google Cloud Console)
# Pour Android : aussi ajouter dans android/local.properties
# Pour iOS : aussi ajouter dans ios/Runner/Info.plist (remplacer la valeur)
# Pour le build Flutter : --dart-define=GOOGLE_MAPS_API_KEY=xxx
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# Firebase (configuré via flutterfire)
# Les clés Firebase sont dans lib/firebase_options.dart

# Contact & Support
# Numéro de téléphone du support
SUPPORT_PHONE=+2250701159572

# Numéro WhatsApp du support (format international sans +)
SUPPORT_WHATSAPP=2250701159572

# Email du support
SUPPORT_EMAIL=support@drlpharma.com

# Infobip Mobile Messaging
# Application Code du portail Infobip (App Profile > Application Code)
# Obtenir depuis: https://portal.infobip.com/apps
INFOBIP_APPLICATION_CODE=
