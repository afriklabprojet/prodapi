<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@drawable/widget_background">

    <!-- Header avec logo et statut -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="DR-PHARMA" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="DR-PHARMA"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1E1E1E" />

        <!-- Indicateur de statut -->
        <TextView
            android:id="@+id/status_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="Hors ligne"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:background="@drawable/status_badge_offline" />
    </LinearLayout>

    <!-- Section livraison active ou stats -->
    <LinearLayout
        android:id="@+id/content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header"
        android:layout_marginTop="12dp"
        android:orientation="vertical">

        <!-- Pas de livraison: afficher stats -->
        <LinearLayout
            android:id="@+id/stats_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="visible">

            <!-- Livraisons du jour -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/today_deliveries"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#1E88E5" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Livraisons"
                    android:textSize="12sp"
                    android:textColor="#666666" />
            </LinearLayout>

            <!-- Gains du jour -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/today_earnings"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 FCFA"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#4CAF50" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gains"
                    android:textSize="12sp"
                    android:textColor="#666666" />
            </LinearLayout>
        </LinearLayout>

        <!-- Livraison active -->
        <LinearLayout
            android:id="@+id/delivery_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="@drawable/delivery_card_background"
            android:visibility="gone">

            <TextView
                android:id="@+id/delivery_status_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="En route vers"
                android:textSize="12sp"
                android:textColor="#666666" />

            <TextView
                android:id="@+id/destination_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pharmacie"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1E1E1E"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/estimated_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="ETA: --"
                android:textSize="14sp"
                android:textColor="#1E88E5" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bouton d'action -->
    <Button
        android:id="@+id/action_button"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_alignParentBottom="true"
        android:layout_marginTop="12dp"
        android:text="Passer en ligne"
        android:textSize="14sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/button_primary"
        android:textAllCaps="false" />

</RelativeLayout>
