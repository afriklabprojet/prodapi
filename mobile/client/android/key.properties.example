# Android Keystore Configuration — DR-PHARMA Client
# Copier ce fichier: cp key.properties.example key.properties
# Puis renseigner les valeurs avec votre keystore
#
# Générer un keystore:
#   keytool -genkey -v -keystore drpharma-client.keystore \
#     -alias drpharma-client -keyalg RSA -keysize 2048 -validity 10000 \
#     -storepass YOUR_STORE_PASSWORD -keypass YOUR_KEY_PASSWORD \
#     -dname "CN=DR-PHARMA, OU=Mobile, O=DRL NEGOCE SARL, L=Abidjan, C=CI"

storePassword=YOUR_STORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=drpharma-client
storeFile=keystores/drpharma-client.keystore
