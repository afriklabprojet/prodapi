# Android Keystore Configuration — DR-PHARMA Pharmacie
# Copier ce fichier: cp key.properties.example key.properties
# Puis renseigner les valeurs avec votre keystore
#
# Générer un keystore:
#   keytool -genkey -v -keystore drpharma-pharmacy.keystore \
#     -alias drpharma-pharmacy -keyalg RSA -keysize 2048 -validity 10000 \
#     -storepass YOUR_STORE_PASSWORD -keypass YOUR_KEY_PASSWORD \
#     -dname "CN=DR-PHARMA Pharmacie, OU=Mobile, O=DRL NEGOCE SARL, L=Abidjan, C=CI"

storePassword=YOUR_STORE_PASSWORD
keyPassword=YOUR_KEY_PASSWORD
keyAlias=drpharma-pharmacy
storeFile=keystores/drpharma-pharmacy.keystore
