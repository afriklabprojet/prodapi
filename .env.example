# ===================================================
# DR-PHARMA API - Environment Configuration
# ===================================================
# Copy this file to .env and configure your values
# cp .env.example .env && php artisan key:generate
# ===================================================

APP_NAME="DR-PHARMA"
APP_ENV=local
APP_KEY=
APP_DEBUG=false  # Mettre true UNIQUEMENT en développement local
APP_URL=http://127.0.0.1:8000

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ===================================================
# Logging Configuration
# ===================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ===================================================
# Database Configuration
# ===================================================
# For SQLite (default for development):
DB_CONNECTION=sqlite
# Note: Create the database file: touch database/database.sqlite

# For MySQL (production):
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=drpharma
# DB_USERNAME=root
# DB_PASSWORD=

# ===================================================
# Session & Cache Configuration
# ===================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ===================================================
# Redis Configuration (optional)
# ===================================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ===================================================
# Mail Configuration (Resend)
# ===================================================
# Resend est le service d'envoi d'emails utilisé par DR-PHARMA
# Documentation: https://resend.com/docs
# Créez un compte sur https://resend.com et obtenez votre clé API
MAIL_MAILER=resend
MAIL_FROM_ADDRESS="noreply@drlpharma.com"
MAIL_FROM_NAME="${APP_NAME}"

# Clé API Resend (commençant par re_)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===================================================
# AWS Configuration (optional)
# ===================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ===================================================
# JEKO Payment Gateway (seul gateway de paiement)
# ===================================================
# Documentation: https://cockpit.jeko.africa → Settings → Webhook & API
JEKO_API_URL=https://api.jeko.africa
JEKO_API_KEY=your_jeko_api_key
JEKO_API_KEY_ID=your_jeko_api_key_id
JEKO_STORE_ID=your_jeko_store_id
JEKO_WEBHOOK_SECRET=your_jeko_webhook_secret

# MODE PAIEMENT: false = Production (paiement réel), true = Sandbox (simulation)
JEKO_SANDBOX_MODE=true

# URLs de callback pour Jeko (DOIVENT être des URLs HTTPS publiques en production)
JEKO_RETURN_URL=https://your-domain.com/api/payments/callback/success
JEKO_ERROR_URL=https://your-domain.com/api/payments/callback/error

# SECURITY: Whitelist des IPs autorisées pour les webhooks Jeko
# Format: liste d'IPs séparées par des virgules
# IMPORTANT: En production, cette variable DOIT être configurée
JEKO_WEBHOOK_IPS=

# ===================================================
# Firebase Configuration (Push Notifications)
# ===================================================
# Download credentials JSON from Firebase Console
FIREBASE_CREDENTIALS=storage/app/firebase-credentials.json

# ===================================================
# SMS Configuration (Infobip)
# ===================================================
SMS_DRIVER=infobip
# Infobip Credentials (shared between SMS and WhatsApp)
INFOBIP_BASE_URL=https://xxxxx.api.infobip.com
INFOBIP_API_KEY=your_infobip_api_key
# Sender ID (registered in Infobip portal)
INFOBIP_SMS_SENDER=DRPHARMA
INFOBIP_SMS_TRANSLITERATION=CENTRAL_EUROPEAN
INFOBIP_SMS_VALIDITY_PERIOD=2880
INFOBIP_SMS_TRACK_DELIVERY=true
INFOBIP_SMS_INTERMEDIATE_REPORTS=false
INFOBIP_SMS_CALLBACK_PREFIX=drpharma_
INFOBIP_SMS_WEBHOOK_URL=https://yourdomain.com/api/webhooks/sms/delivery
INFOBIP_SMS_V3_ENABLED=false
# Log SMS messages to file
SMS_LOG_MESSAGES=true
SMS_LOG_CHANNEL=sms
# Phone normalization (Côte d'Ivoire)
SMS_DEFAULT_COUNTRY_CODE=+225
# Rate limiting
SMS_RATE_LIMIT=30

# ===================================================
# WhatsApp via Infobip
# ===================================================
WHATSAPP_ENABLED=true
# Falls back to INFOBIP_BASE_URL / INFOBIP_API_KEY if not set
WHATSAPP_INFOBIP_BASE_URL=
WHATSAPP_INFOBIP_API_KEY=
WHATSAPP_SENDER_NUMBER=15558636493
WHATSAPP_DEFAULT_LANGUAGE=fr
WHATSAPP_DEFAULT_COUNTRY_CODE=+225
WHATSAPP_SMS_FAILOVER=false
WHATSAPP_WEBHOOK_URL=

# ===================================================
# Debug Tools
# ===================================================
TELESCOPE_ENABLED=true

# ===================================================
# CORS Configuration
# ===================================================
# Frontend URL principale (incluse automatiquement dans CORS)
FRONTEND_URL=http://localhost:3000

# Origines CORS additionnelles (séparées par des virgules)
# Production: https://drpharma.ci,https://app.drpharma.ci
CORS_ALLOWED_ORIGINS=

# Patterns regex pour origines dynamiques (sous-domaines)
# Exemple: /^https:\/\/.*\.drpharma\.ci$/
CORS_ALLOWED_PATTERNS=

VITE_APP_NAME="${APP_NAME}"

# ===================================================
# Google Maps
# ===================================================
GOOGLE_MAPS_API_KEY=

# ===================================================
# Google Vision API (KYC Validation)
# ===================================================
GOOGLE_VISION_ENABLED=true
GOOGLE_APPLICATION_CREDENTIALS=
