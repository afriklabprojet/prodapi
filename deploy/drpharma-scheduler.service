# /etc/systemd/system/drpharma-scheduler.service
[Unit]
Description=DR-PHARMA Laravel Scheduler
After=network.target mysql.service

[Service]
Type=oneshot
User=drpharma
WorkingDirectory=/var/www/drpharma/api
ExecStart=/usr/bin/php artisan schedule:run
StandardOutput=append:/var/www/drpharma/api/storage/logs/scheduler.log
StandardError=append:/var/www/drpharma/api/storage/logs/scheduler.log
