# ============================================
# DR-PHARMA - Redirection vers public/
# ============================================
# Ce fichier va à la RACINE de public_html/
# Il redirige tout le trafic vers le dossier public/
# pour protéger les fichiers sensibles (.env, config/, etc.)

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Rediriger tout vers le dossier public/
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ /public/$1 [L]
</IfModule>
